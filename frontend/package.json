{
  "name": "stock-options-signal-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:examples",
    "build:examples": "node scripts/build-chart-examples.mjs",
    "preview": "vite preview",
    "test:operator-telemetry": "node scripts/operator-telemetry-smoke.mjs",
    "test:chart-engine": "node --experimental-specifier-resolution=node scripts/chart-engine-smoke.mjs",
    "test:chart-regression": "node --experimental-specifier-resolution=node scripts/chart-engine-regression.mjs",
    "test:chart-browser": "node scripts/chart-engine-browser-regression.mjs",
    "benchmark:chart-engine": "node --experimental-specifier-resolution=node scripts/chart-engine-benchmark.mjs",
    "test": "npm run build",
    "check": "npm run build"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "playwright": "^1.59.1",
    "vite": "^8.0.3"
  }
}
