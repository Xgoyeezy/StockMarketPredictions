APP_NAME=Stock Options Signal API
APP_VERSION=2.6.0
APP_PHASE=release-candidate
APP_ENV=production

API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
REQUEST_LOGGING=true

ALLOW_ORIGINS=https://your-frontend.example.com
FRONTEND_DEV_URL=https://your-frontend.example.com
PUBLIC_API_BASE_URL=https://your-api.example.com/api

APP_STORAGE_DIR=/var/lib/stocksignals
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/stocksignals
DATABASE_ECHO=false

AUTH_ENABLED=true
ALLOW_DEMO_AUTH=false
AUTH_PROVIDER=local-session

AUTH_SESSION_COOKIE_NAME=stocksignals_session
AUTH_SESSION_SECRET=replace-with-strong-session-secret
AUTH_SESSION_MAX_AGE_SECONDS=1209600
AUTH_SESSION_SECURE=true
AUTH_STATE_COOKIE_NAME=stocksignals_auth_state
AUTH_STATE_SECRET=replace-with-strong-auth-state-secret
AUTH_STATE_MAX_AGE_SECONDS=600
LOCAL_AUTH_ALLOW_SIGNUP=true
LOCAL_AUTH_DEFAULT_PLAN=starter

API_TOKEN_SALT=replace-with-strong-api-token-salt

JOB_WORKER_ENABLED=true
JOB_WORKER_POLL_SECONDS=3
JOB_WORKER_BATCH_SIZE=12

REALTIME_STREAM_ENABLED=true
REALTIME_MAX_TICKERS=12
MARKET_DATA_PROVIDER=alpaca
APCA_API_KEY_ID=replace-with-alpaca-key
APCA_API_SECRET_KEY=replace-with-alpaca-secret
ALPACA_STOCK_STREAM_VERSION=v2
ALPACA_STOCK_FEED=iex
ALPACA_USE_SANDBOX=false

STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
BILLING_CHECKOUT_SUCCESS_URL=https://your-frontend.example.com/settings?billing=success
BILLING_CHECKOUT_CANCEL_URL=https://your-frontend.example.com/settings?billing=cancel
STRIPE_PRICE_STARTER_MONTHLY=price_replace_me
STRIPE_PRICE_STARTER_ANNUAL=price_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_PRO_ANNUAL=price_replace_me
STRIPE_PRICE_TEAM_MONTHLY=price_replace_me
STRIPE_PRICE_TEAM_ANNUAL=price_replace_me
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_replace_me
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_replace_me
STRIPE_PRICE_WHITE_LABEL_MONTHLY=price_replace_me
STRIPE_PRICE_WHITE_LABEL_ANNUAL=price_replace_me
