APP_NAME=Stock Options Signal API
APP_VERSION=2.6.0
APP_PHASE=release-candidate
APP_ENV=development
API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
REQUEST_LOGGING=true
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
APP_STORAGE_DIR=backend/storage
AUTH_ENABLED=false
ALLOW_DEMO_AUTH=true
AUTH_PROVIDER=local-demo
DEMO_USER_ID=demo-trader
DEMO_USER_EMAIL=demo@stocksignals.local
DEMO_USER_NAME=Demo Trader
REALTIME_STREAM_ENABLED=true
REALTIME_MAX_TICKERS=12
MARKET_DATA_ADAPTER=hybrid
MARKET_DATA_PROVIDER=alpaca
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_OAUTH_CLIENT_ID=
ALPACA_OAUTH_CLIENT_SECRET=
ALPACA_OAUTH_AUTHORIZE_URL=https://app.alpaca.markets/oauth/authorize
ALPACA_OAUTH_TOKEN_URL=https://api.alpaca.markets/oauth/token
ALPACA_OAUTH_REDIRECT_URI=http://localhost:8000/api/me/brokerage-accounts/alpaca/callback
ALPACA_OAUTH_SCOPE=account:write trading
ALPACA_MARKET_DATA_REQUEST_TIMEOUT_SECONDS=10
ALPACA_STOCK_STREAM_VERSION=v2
ALPACA_STOCK_FEED=iex
ALPACA_OPTIONS_FEED=opra
OPTIONS_SCAN_INTERVAL_SECONDS=30
OPTIONS_QUOTE_MAX_AGE_SECONDS=30
OPTIONS_MAX_SPREAD_PCT=0.15
OPTIONS_MIN_VOLUME=25
OPTIONS_MIN_OPEN_INTEREST=100
OPTIONS_MIN_DTE_DAYS=7
OPTIONS_MAX_DTE_DAYS=45
OPTIONS_SCAN_CANDIDATE_LIMIT=30
OPTIONS_MAX_PREMIUM_RISK_PCT=1.0
OPTIONS_MAX_OPEN_POSITIONS=4
ALPACA_USE_SANDBOX=false
POLYGON_API_KEY=
POLYGON_API_BASE_URL=https://api.polygon.io
POLYGON_REQUEST_TIMEOUT_SECONDS=10
HYBRID_MARKET_STATE_TTL_SECONDS=90
HYBRID_RELATIVE_STRENGTH_TTL_SECONDS=90
HYBRID_OPTIONS_FLOW_TTL_SECONDS=180
HYBRID_EVENT_REVISION_TTL_SECONDS=900
